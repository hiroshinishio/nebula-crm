# Auth mode: 'oidc' for all non-local environments | 'dev' for local dev bypass only.
# NEVER set to 'dev' in staging or production.
VITE_AUTH_MODE=oidc
VITE_OIDC_AUTHORITY=http://localhost:9000/application/o/nebula/
VITE_OIDC_CLIENT_ID=nebula
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
