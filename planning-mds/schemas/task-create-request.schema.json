{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nebula.local/schemas/task-create-request.schema.json",
  "title": "TaskCreateRequest",
  "description": "Validation rules for creating a task. F0005-aligned: assignedToUserId is uuid.",
  "type": "object",
  "required": [
    "title",
    "assignedToUserId"
  ],
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 255
    },
    "description": {
      "type": "string",
      "maxLength": 2000
    },
    "priority": {
      "type": "string",
      "enum": ["Low", "Normal", "High", "Urgent"],
      "default": "Normal"
    },
    "dueDate": {
      "type": "string",
      "format": "date"
    },
    "assignedToUserId": {
      "type": "string",
      "format": "uuid",
      "description": "Internal UserId (uuid) from UserProfile. Must match authenticated user's UserId in MVP (self-assigned only)."
    },
    "linkedEntityType": {
      "type": "string",
      "enum": ["Broker", "Account", "Submission", "Renewal"]
    },
    "linkedEntityId": {
      "type": "string",
      "format": "uuid"
    }
  },
  "dependencies": {
    "linkedEntityType": ["linkedEntityId"],
    "linkedEntityId": ["linkedEntityType"]
  },
  "additionalProperties": false
}
